// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique
  name      String?
  username  String?  @unique
  email     String   @unique
  image     String?
  bio       String?
  onboarded Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Hosted meetings (one-to-many)
  hostedMeetings Meeting[] @relation("hostedMeetings")
  
  // Meeting participations (many-to-many)
  participations MeetingParticipant[]
}

model Meeting {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId      String   @unique
  title       String?
  description String?
  scheduled   Boolean  @default(false)
  startTime   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Host relationship (many-to-one)
  hostId      String   @db.ObjectId
  host        User     @relation("hostedMeetings", fields: [hostId], references: [id], onDelete: Cascade)
  
  // Participant relationships (many-to-many through join model)
  participants MeetingParticipant[]
}

// Join model for many-to-many relationship between User and Meeting
model MeetingParticipant {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // User relationship
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Meeting relationship
  meetingId String   @db.ObjectId
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  // Additional fields for the relationship
  joinedAt  DateTime @default(now())
  leftAt    DateTime?
  
  @@unique([userId, meetingId])
}
